{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "noEmitOnError": false,
    "types": ["vitest/globals", "node"]
  },
  "include": ["*.ts", "bin/**/*.js", "scripts/**/*.mts", "scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["coverage", "dist", "node_modules", "out-tsc", "test-output"]
}
