{
  "name": "@clipboard-health/groundcrew",
  "version": "5.0.0-alpha.0",
  "private": true,
  "type": "module",
  "bin": {
    "crew": "./bin/run.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc --noEmit",
    "architecture:check": "depcruise --config config/dependencyCruiser.cjs src e2e bin",
    "test": "vitest run --coverage",
    "test:bundles": "node --test 'task-sources/**/*.test.mts'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "verify": "node --run typecheck && node --run build && node --run architecture:check && node --run test"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.65",
    "@commander-js/extra-typings": "14.0.0",
    "agent-trust": "1.0.0",
    "commander": "14.0.2",
    "execa": "9.6.0",
    "jsonc-parser": "3.3.1",
    "p-limit": "7.1.1",
    "p-retry": "7.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.9.5",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.0.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
