#!/usr/bin/env node
"use strict";

// Protocol-1 `list` command (contracts §4). Reads a JSON task store pointed to
// by $FIXTURE_STORE, journals the call to calls.jsonl next to the store, and
// emits the ready/queued view on stdout. Store knobs: `failList` (emit a
// protocol failure), `completedTaskIds`/`recurringTaskIds` (a completed task
// drops out of the queue unless it recurs — DISPATCH-09). No deps outside node.

const fs = require("node:fs");
const path = require("node:path");

const COMMAND = "list";

main();

function main() {
  const storePath = requireStorePath();
  const stdin = readStdin();
  journal(storePath, stdin);

  const store = JSON.parse(fs.readFileSync(storePath, "utf8"));
  if (store.failList) {
    fail("list failed (fixture failList knob)");
  }

  const completed = new Set(store.completedTaskIds || []);
  const recurring = new Set(store.recurringTaskIds || []);
  const tasks = (store.tasks || []).filter(
    (task) => !completed.has(task.id) || recurring.has(task.id),
  );

  emit({ ok: true, data: { tasks } });
}

function requireStorePath() {
  const value = process.env.FIXTURE_STORE;
  if (!value) {
    fail("FIXTURE_STORE is not set");
  }

  return value;
}

function readStdin() {
  try {
    const raw = fs.readFileSync(0, "utf8");
    return raw.trim() === "" ? {} : JSON.parse(raw);
  } catch {
    return {};
  }
}

function journal(storePath, stdin) {
  const entry = {
    command: COMMAND,
    args: process.argv.slice(2),
    stdin,
    timestamp: new Date().toISOString(),
  };
  fs.appendFileSync(
    path.join(path.dirname(storePath), "calls.jsonl"),
    JSON.stringify(entry) + "\n",
  );
}

function emit(object) {
  process.stdout.write(JSON.stringify(object) + "\n");
  process.exit(0);
}

function fail(message) {
  process.stdout.write(JSON.stringify({ ok: false, error: { message } }) + "\n");
  process.exit(0);
}
